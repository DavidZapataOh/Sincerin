pe\":\"uint256\",\"name\":\"totalProofs\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"failedProofs\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"totalLatency\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"active\",\"type\":\"bool\"},{\"internalType\":\"uint256\",\"name\":\"registeredAt\",\"type\":\"uint256\"}],\"internalType\":\"struct IProverRegistry.ProverInfo\",\"name\":\"\",\"type\":\"tuple\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"getProverCount\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"prover\",\"type\":\"address\"}],\"name\":\"isActive\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"minStake\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"owner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"register\",\"outputs\":[],\"stateMutability\":\"payable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"_coordinator\",\"type\":\"address\"}],\"name\":\"setCoordinator\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"prover\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"reason\",\"type\":\"string\"}],\"name\":\"slash\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"targetLatencyMs\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"prover\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"latencyMs\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"success\",\"type\":\"bool\"}],\"name\":\"updateReputation\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"Sincerin Protocol\",\"details\":\"Provers stake native tokens to register, earn reputation through successful proof      generation, and face slashing for misbehavior. Reputation uses a weighted moving      average based on latency performance (0-10000 basis points). The Coordinator      contract is the sole authority for reputation updates and slashing.\",\"events\":{\"ProverDeregistered(address)\":{\"params\":{\"prover\":\"Address of the deregistered prover\"}},\"ProverRegistered(address,uint256)\":{\"params\":{\"prover\":\"Address of the registered prover\",\"stake\":\"Amount of stake deposited\"}},\"ProverSlashed(address,uint256,string)\":{\"params\":{\"amount\":\"Amount of stake slashed\",\"prover\":\"Address of the slashed prover\",\"reason\":\"Human-readable slashing reason\"}},\"ReputationUpdated(address,uint256)\":{\"params\":{\"newScore\":\"Updated reputation score (0-10000 basis points)\",\"prover\":\"Address of the prover\"}}},\"kind\":\"dev\",\"methods\":{\"constructor\":{\"params\":{\"_minStake\":\"Minimum native token stake required for prover registration (wei)\",\"_targetLatencyMs\":\"Target proof generation latency in milliseconds\"}},\"getProver(address)\":{\"params\":{\"prover\":\"Address of the prover\"},\"returns\":{\"_0\":\"The complete ProverInfo struct\"}},\"getProverCount()\":{\"details\":\"Includes inactive/deregistered provers. Use isActive() to filter.\",\"returns\":{\"_0\":\"The length of the prover list\"}},\"isActive(address)\":{\"params\":{\"prover\":\"Address of the prover\"},\"returns\":{\"_0\":\"True if the prover is registered and active\"}},\"register()\":{\"details\":\"Requires msg.value >= minStake\"},\"setCoordinator(address)\":{\"details\":\"Only callable by the owner. The Coordinator is the sole authority for      reputation updates and slashing operations.\",\"params\":{\"_coordinator\":\"Address of the Coordinator contract\"}},\"slash(address,uint256,string)\":{\"details\":\"Reduces the prover's stake by the specified amount. If the remaining stake      falls below minStake, the prover is automatically deactivated. Slashed funds      are held by this contract (can be extended for treasury/burn in future).\",\"params\":{\"amount\":\"Amount of stake to slash\",\"prover\":\"Address of the prover to slash\",\"reason\":\"Human-readable slashing reason\"}},\"updateReputation(address,uint256,bool)\":{\"details\":\"Reputation scoring logic:      - On failure: reputation reduced by FAILURE_PENALTY (floored at 0)      - On success: latencyScore computed as linear interpolation between        MAX_REPUTATION (at or below targetLatencyMs) and 0 (at or above        targetLatencyMs * LATENCY_CEILING_MULTIPLIER)      - Weighted moving average: newRep = (oldRep * (totalProofs - 1) + latencyScore) / totalProofs      - Capped at MAX_REPUTATION\",\"params\":{\"latencyMs\":\"Time in ms from request to proof submission\",\"prover\":\"Address of the prover\",\"success\":\"Whether the proof was verified successfully\"}}},\"stateVariables\":{\"LATENCY_CEILING_MULTIPLIER\":{\"details\":\"Latencies at or above targetLatencyMs * LATENCY_CEILING_MULTIPLIER score 0\"},\"s_proverList\":{\"details\":\"Used for enumeration. Includes inactive provers.\"},\"targetLatencyMs\":{\"details\":\"Provers meeting this target receive maximum latency score (10000)\"}},\"title\":\"ProverRegistry\",\"version\":1},\"userdoc\":{\"events\":{\"ProverDeregistered(address)\":{\"notice\":\"Emitted when a prover deregisters\"},\"ProverRegistered(address,uint256)\":{\"notice\":\"Emitted when a prover registers with stake\"},\"ProverSlashed(address,uint256,string)\":{\"notice\":\"Emitted when a prover is slashed\"},\"ReputationUpdated(address,uint256)\":{\"notice\":\"Emitted when a prover's reputation is updated\"}},\"kind\":\"user\",\"methods\":{\"constructor\":{\"notice\":\"Deploys the ProverRegistry with initial configuration\"},\"coordinator()\":{\"notice\":\"Address of the Coordinator contract authorized to update reputation and slash\"},\"deregister()\":{\"notice\":\"Deregister and withdraw remaining stake\"},\"getProver(address)\":{\"notice\":\"Get prover information\"},\"getProverCount()\":{\"notice\":\"Returns the total number of provers that have ever registered\"},\"isActive(address)\":{\"notice\":\"Check if a prover is currently active\"},\"minStake()\":{\"notice\":\"Minimum stake required to register as a prover (in wei)\"},\"owner()\":{\"notice\":\"Address of the contract owner (can set coordinator, update parameters)\"},\"register()\":{\"notice\":\"Register as a prover with msg.value as stake\"},\"setCoordinator(address)\":{\"notice\":\"Sets the Coordinator contract address\"},\"slash(address,uint256,string)\":{\"notice\":\"Slash a prover's stake\"},\"targetLatencyMs()\":{\"notice\":\"Target proof generation latency in milliseconds\"},\"updateReputation(address,uint256,bool)\":{\"notice\":\"Update a prover's reputation based on proof outcome\"}},\"notice\":\"Manages prover registration, staking, reputation scoring, and slashing\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/ProverRegistry.sol\":\"ProverRegistry\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":10000},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"src/ProverRegistry.sol\":{\"keccak256\":\"0xb728e3b264bcdccae6cbb0965a3728d5e22881ce7ea58ae485e4e911af1284fa\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://408adccca1e0ebc8034d19f5d775e6336c9cc1ae2abd46a12d055c5c7998ee8a\",\"dweb:/ipfs/QmXuXEahLPc5VQjKosQwkpFn6n7tDf7Smerq